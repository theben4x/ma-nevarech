{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "mylogo.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/mylogo.png",
      "dest": "/mylogo.png"
    },
    {
      "src": "/(.*)",
      "dest": "/main.py"
    }
  ]
}
